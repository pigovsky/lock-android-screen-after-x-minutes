<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Greeting Text:" />

    <EditText
        android:id="@+id/edit_greeting_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter greeting message" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Alarm Message:" />

    <EditText
        android:id="@+id/edit_alarm_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter alarm message" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Language Code (e.g., uk, en, en-GB):" />

    <EditText
        android:id="@+id/edit_language"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Language code" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Time Narration Interval (24h format):" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/edit_start_hour"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Start Hour (e.g., 8)"
            android:inputType="number" />

        <EditText
            android:id="@+id/edit_end_hour"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="End Hour (e.g., 9)"
            android:inputType="number" />
    </LinearLayout>

    <Button
        android:id="@+id/save_settings_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Save Settings" />

</LinearLayout>